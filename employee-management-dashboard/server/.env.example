# --- Server configuration ---
PORT=5000

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/ems
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/ems?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/ems

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Credentials created by the seed script for the demo admin user.
SEED_ADMIN_EMAIL=admin@ems.com
SEED_ADMIN_PASSWORD=admin123

# Allowed origin for CORS (the Vite dev server).
CLIENT_ORIGIN=http://localhost:5173
